    public DateTimeOffset MapeDateFin   { get; set; }

    public ObservableCollection<LigneMapeVM> LignesMape { get; } = new();

    private void InitMape()
    {
        LignesMape.Clear();
        foreach (var (nom, urgente) in MapeConstants.Maladies)
            LignesMape.Add(new LigneMapeVM { Maladie = nom, EstUrgente = urgente });
    }

    private static int GetSemaineActuelle()
    {
        var cal = System.Globalization.CultureInfo.InvariantCulture.Calendar;
        return cal.GetWeekOfYear(DateTime.Now,
            System.Globalization.CalendarWeekRule.FirstFourDayWeek,
            DayOfWeek.Monday);
    }

    // =============================================
    // CHARGEMENT
    // =============================================
    public async Task LoadAsync()
    {
        var user = AuthenticationService.CurrentUser;
        if (user == null) return;

        if (user.Role == RoleType.SuperAdmin)
        {
            // SuperAdmin : charge tous les services et voit tout
            var services = await _context.Services.Where(s => s.Actif).OrderBy(s => s.Libelle).ToListAsync();
            ServicesDisponibles.Clear();
            foreach (var s in services) ServicesDisponibles.Add(s);
            SetMenusVisibles(null); // Tout visible
        }
        else
        {
            // Agent : chargement du service affecté
            ServiceActuel = user.ServiceId.HasValue
                ? await _context.Services.FindAsync(user.ServiceId)
                : null;
            OnPropertyChanged(nameof(ServiceNom));
            OnPropertyChanged(nameof(ServiceActuel));
            SetMenusVisibles(ServiceActuel?.Code);

            // Aller directement au bon onglet
            NaviguerVersOngletService(ServiceActuel?.Code);
        }

        await ChargerDernieresSaisies();
    }

    /// <summary>
    /// Définit quels menus sont visibles selon le code service de l'agent
    /// </summary>
    private void SetMenusVisibles(string? serviceCode)
    {
        if (serviceCode == null)
        {
            // SuperAdmin ou aucun service → tout visible
            MenuConsultationVisible    = true;
            MenuHospitalisationVisible = true;
            MenuChirurgieVisible       = true;
            MenuUrgencesVisible        = true;
            MenuDecesVisible           = true;
            MenuLaboVisible            = true;
            MenuVaccinationVisible     = true;
            MenuBanqueSangVisible      = true;
            MenuMorgueVisible          = true;
        }
        else
        {
            // Par défaut : rien
            MenuConsultationVisible    = false;
            MenuHospitalisationVisible = false;
            MenuChirurgieVisible       = false;
            MenuUrgencesVisible        = false;
            MenuDecesVisible           = false;
            MenuLaboVisible            = false;
            MenuVaccinationVisible     = false;
            MenuBanqueSangVisible      = false;
            MenuMorgueVisible          = false;

            // Activer selon le code service
            switch (serviceCode)
            {
                // Services de consultation uniquement
                case "OPHTALMO":
                case "ODONTO":
                case "CARDIO":
                case "PSYCHIATRIE":
                case "ENDOCRINO":
                case "NEURO_MED":
                case "HEMATO":
                case "PNEUMO":
                case "RHUMATO":
                case "DERMATO":
                case "HGE":
                case "CPN":
                    MenuConsultationVisible = true;
                    break;

                // Chirurgie : consultation + hospitalisation + chirurgie + décès
                case "CHIR_GEN":
                case "CHIR_PED":
                case "NEURO":
                case "TRAUMA":
                case "MAXILLO":
                case "CHIR_VISC":
                    MenuConsultationVisible    = true;
                    MenuHospitalisationVisible = true;
                    MenuChirurgieVisible       = true;
                    MenuDecesVisible           = true;
                    break;

                // Médecine : consultation + hospitalisation + décès
                case "MED_GEN":
                case "MED_INT":
                case "ONCOLOGIE":
                case "NUTRITION":
                case "REANIMATION":
                    MenuConsultationVisible    = true;
                    MenuHospitalisationVisible = true;
                    MenuDecesVisible           = true;
                    break;

                // Gynéco/Obstétrique : tout sauf morgue/labo/vaccin/banque sang
                case "GYNECO":
                    MenuConsultationVisible    = true;
                    MenuHospitalisationVisible = true;
                    MenuDecesVisible           = true;
                    break;

                // Pédiatrie + Néonatalogie
                case "PEDIATRIE":
                case "NEONAT":
                    MenuConsultationVisible    = true;
                    MenuHospitalisationVisible = true;
                    MenuDecesVisible           = true;
                    break;

                // Urgences
                case "URGENCES":
                    MenuConsultationVisible = true;
                    MenuUrgencesVisible     = true;
                    MenuDecesVisible        = true;
                    break;

                // Laboratoire
                case "LABO":
                case "ANAPATH":
                    MenuLaboVisible = true;
                    break;

                // Vaccination
                case "VACCIN":
                    MenuVaccinationVisible = true;
                    break;

                // Banque de sang
                case "BANQ_SANG":
                    MenuBanqueSangVisible = true;
                    break;

                // Morgue
                case "MORGUE":
                    MenuMorgueVisible = true;
                    MenuDecesVisible  = true;
                    break;

                // Kinésithérapie — utilise consultation comme proxy
                case "KINE":
                    MenuConsultationVisible = true;
                    break;

                default:
                    MenuConsultationVisible = true;
                    break;
            }
        }

        NotifyMenusVisibles();
    }

    private void NaviguerVersOngletService(string? serviceCode)
    {
        // Aller directement au premier onglet disponible pour ce service
        if (MenuConsultationVisible)    OngletActif = 0;
        else if (MenuHospitalisationVisible) OngletActif = 1;
        else if (MenuChirurgieVisible)  OngletActif = 2;
        else if (MenuUrgencesVisible)   OngletActif = 3;
        else if (MenuDecesVisible)      OngletActif = 4;
        else if (MenuLaboVisible)       OngletActif = 5;
        else if (MenuVaccinationVisible) OngletActif = 6;
        else if (MenuBanqueSangVisible) OngletActif = 7;
        else if (MenuMorgueVisible)     OngletActif = 8;
        else OngletActif = 9;
    }

    private void NotifyMenusVisibles()
    {
        OnPropertyChanged(nameof(MenuConsultationVisible));
        OnPropertyChanged(nameof(MenuHospitalisationVisible));
        OnPropertyChanged(nameof(MenuChirurgieVisible));
        OnPropertyChanged(nameof(MenuUrgencesVisible));
        OnPropertyChanged(nameof(MenuDecesVisible));
        OnPropertyChanged(nameof(MenuLaboVisible));
        OnPropertyChanged(nameof(MenuVaccinationVisible));
        OnPropertyChanged(nameof(MenuBanqueSangVisible));
        OnPropertyChanged(nameof(MenuMorgueVisible));
        NotifyOnglets();
    }

    private async Task ChargerDernieresSaisies()
    {
        var user = AuthenticationService.CurrentUser;
        if (user == null) return;

        var list = new List<SaisieInfo>();

        IQueryable<SaisieConsultation> qC = _context.SaisiesConsultation
            .Include(s => s.Service).Include(s => s.SaisiePar);
        if (user.Role != RoleType.SuperAdmin && user.ServiceId.HasValue)
            qC = qC.Where(s => s.ServiceId == user.ServiceId);

        var consults = await qC.OrderByDescending(s => s.DateSaisie).Take(10).ToListAsync();
        list.AddRange(consults.Select(c => new SaisieInfo
        {
            Type = "Consultation", Service = c.Service?.Libelle ?? "-",
            Date = c.DateSaisie,
            Total = c.TotalGeneral, Validee = c.Validee
        }));

        IQueryable<SaisieHospitalisation> qH = _context.SaisiesHospitalisation
            .Include(s => s.Service).Include(s => s.SaisiePar);
        if (user.Role != RoleType.SuperAdmin && user.ServiceId.HasValue)
            qH = qH.Where(s => s.ServiceId == user.ServiceId);

        var hosps = await qH.OrderByDescending(s => s.DateSaisie).Take(5).ToListAsync();
        list.AddRange(hosps.Select(h => new SaisieInfo
        {
            Type = "Hospitalisation", Service = h.Service?.Libelle ?? "-",
            Date = h.DateSaisie,
            Total = h.Total, Validee = h.Validee
        }));

        DernieresSaisies.Clear();
        foreach (var item in list.OrderByDescending(x => x.Date).Take(15))
            DernieresSaisies.Add(item);
    }

    private Service? GetServiceEffectif()
    {
        var user = AuthenticationService.CurrentUser;
        return user?.Role == RoleType.SuperAdmin ? ServiceChoisi : ServiceActuel;
    }

    // =============================================
    // ENREGISTREMENT
    // =============================================
    private async Task EnregistrerAsync()
    {
        var user = AuthenticationService.CurrentUser;
        if (user == null) { SetStatus("Utilisateur non connecté.", false); return; }

        IsSaving = true;
        try
        {
            switch (OngletActif)
            {
                case 0: await EnregistrerConsultationAsync(user);   break;
                case 1: await EnregistrerHospitalisationAsync(user); break;
                case 2: await EnregistrerChirurgieAsync(user);      break;
                case 3: await EnregistrerUrgenceAsync(user);        break;
                case 4: await EnregistrerDecesAsync(user);          break;
                case 5: await EnregistrerLaboAsync(user);           break;
                case 6: await EnregistrerVaccinationAsync(user);    break;
                case 7: await EnregistrerBanqueSangAsync(user);     break;
                case 8: await EnregistrerMorgueAsync(user);         break;
                case 9: await EnregistrerMapeAsync(user);           break;
            }
            await ChargerDernieresSaisies();
        }
        catch (Exception ex)
        {
            SetStatus($"Erreur : {ex.Message} — {ex.InnerException?.Message}", false);
        }
        finally { IsSaving = false; }
    }

    private bool EstValideDirectement(Utilisateur user)
        => user.Role == RoleType.ChefDeSaisie || user.Role == RoleType.SuperAdmin;

    private async Task EnregistrerConsultationAsync(Utilisateur user)
    {
        var svc = GetServiceEffectif();
        if (svc == null) { SetStatus("Sélectionnez un service.", false); return; }
        bool valide = EstValideDirectement(user);
        var s = new SaisieConsultation
        {
            ServiceId = svc.Id, DateSaisie = DateSaisie.DateTime,
            SaisieParId = user.Id,
            NouveauxHommes = ConsultNouveauxH, NouvellesFemmes = ConsultNouvellesF, NouveauxEnfants = ConsultNouveauxE,
            AnciensHommes = ConsultAnciensH, AnciennesFemmes = ConsultAnciennesF, AnciensEnfants = ConsultAnciensE,
            Validee = valide, ValideeParId = valide ? user.Id : null,
            DateValidation = valide ? DateTime.Now : null
        };
        _context.SaisiesConsultation.Add(s);
        await _context.SaveChangesAsync();
        SetStatus($"Consultations enregistrées — Total : {s.TotalGeneral}", true);
    }

    private async Task EnregistrerHospitalisationAsync(Utilisateur user)
    {
        var svc = GetServiceEffectif();
        if (svc == null) { SetStatus("Sélectionnez un service.", false); return; }
        
        // v5: Validation obligatoire - Durée d'hospitalisation requise
        if (HospJours < 1)
        {
            SetStatus("La durée d'hospitalisation (en jours) est OBLIGATOIRE pour valider une sortie.", false);
            return;
        }
        
        string activite = (HospActiviteIndex >= 0 && HospActiviteIndex < ActivitesHosp.Length)
            ? ActivitesHosp[HospActiviteIndex] : string.Empty;
        bool valide = EstValideDirectement(user);
        var s = new SaisieHospitalisation
        {
            ServiceId = svc.Id, TypeActivite = activite,
            DateSaisie = DateSaisie.DateTime, SaisieParId = user.Id,
            Hommes = HospHommes, Femmes = HospFemmes, Enfants = HospEnfants,
            JoursHospitalisation = HospJours,
            Validee = valide, ValideeParId = valide ? user.Id : null,
            DateValidation = valide ? DateTime.Now : null
        };
        _context.SaisiesHospitalisation.Add(s);
        await _context.SaveChangesAsync();
        SetStatus($"Hospitalisations enregistrées — Total : {s.Total} — Jours : {HospJours}", true);
    }

    private async Task EnregistrerChirurgieAsync(Utilisateur user)
    {
        var svc = GetServiceEffectif();
        if (svc == null) { SetStatus("Sélectionnez un service.", false); return; }
        string spec = ChirSpecialiteIndex >= 0 && ChirSpecialiteIndex < SpecialitesChir.Length
            ? SpecialitesChir[ChirSpecialiteIndex] : "Chirurgie";
        bool valide = EstValideDirectement(user);
        var s = new SaisieActeChirurgical
        {
            ServiceId = svc.Id, TypeActe = spec,
            DateSaisie = DateSaisie.DateTime, SaisieParId = user.Id,
            Hommes = ChirHommes, Femmes = ChirFemmes, Enfants = ChirEnfants,
            Validee = valide, ValideeParId = valide ? user.Id : null,
            DateValidation = valide ? DateTime.Now : null
        };
        _context.SaisiesActeChirurgical.Add(s);
        await _context.SaveChangesAsync();
        SetStatus($"Actes chirurgicaux enregistrés — Total : {s.Total}", true);
    }

    private async Task EnregistrerUrgenceAsync(Utilisateur user)
    {
        bool valide = EstValideDirectement(user);
        var s = new SaisieUrgence
        {
            DateSaisie = DateSaisie.DateTime, SaisieParId = user.Id,
            MiseEnObservationH = UrgMEO_H, MiseEnObservationF = UrgMEO_F,
            MiseEnObservationEM = UrgMEO_EM, MiseEnObservationEF = UrgMEO_EF,
            TransfertH = UrgTRF_H, TransfertF = UrgTRF_F, TransfertEM = UrgTRF_EM, TransfertEF = UrgTRF_EF,
            SortieAutoriseeH = UrgSA_H, SortieAutoriseeF = UrgSA_F, SortieAutoriseeEM = UrgSA_EM, SortieAutoriseeEF = UrgSA_EF,
            ScamH = UrgSCAM_H, ScamF = UrgSCAM_F, ScamEM = UrgSCAM_EM, ScamEF = UrgSCAM_EF,
            EvadesH = UrgEV_H, EvadesF = UrgEV_F, EvadesEM = UrgEV_EM, EvadesEF = UrgEV_EF,
            Validee = valide, ValideeParId = valide ? user.Id : null,
            DateValidation = valide ? DateTime.Now : null
        };
        _context.SaisiesUrgence.Add(s);
        await _context.SaveChangesAsync();
        SetStatus("Actes urgences enregistrés.", true);
    }

    private async Task EnregistrerDecesAsync(Utilisateur user)
    {
        var svc = GetServiceEffectif();
        if (svc == null) { SetStatus("Sélectionnez un service.", false); return; }
        
        bool valide = EstValideDirectement(user);
        
        // v5: Utiliser PatientRmaService pour auto-morgue
        var patientService = new PatientRmaService(_context);
        
        try
        {
            var deces = await patientService.EnregistrerDecesEtMorgueAsync(
                serviceId: svc.Id,
                hommes: DecesH,
                femmes: DecesF,
                enfants: DecesE,
                transfereAMorgue: DecesTransfereAMorgue,
                dateSaisie: DateSaisie.DateTime,
                saisieParId: user.Id
            );

            // Valider après créati si applicable
            if (valide)
            {
                deces.Validee = true;
                deces.ValideeParId = user.Id;
                deces.DateValidation = DateTime.Now;
                _context.SaisiesDeces.Update(deces);
                await _context.SaveChangesAsync();
            }

            // Message de confirmation
            string msgMorgue = DecesTransfereAMorgue 
                ? " — Auto-enregistrement morgue activé" 
                : "";
            SetStatus($"Décès enregistrés — Total : {deces.Total}{msgMorgue}", true);
        }
        catch (Exception ex)
        {
            SetStatus($"Erreur enregistrement décès: {ex.Message}", false);
        }
    }

