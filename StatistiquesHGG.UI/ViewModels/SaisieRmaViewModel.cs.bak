            JoursH = MorgueJoursH, JoursF = MorgueJoursF, JoursE = MorgueJoursE,
            // v5: Distinguer source (hôpital ou externe)
            CasFromHopital = MorgueCasFromHopital,
            CasExterieurs = MorgueCasExterieurs,
            Validee = valide, ValideeParId = valide ? user.Id : null,
