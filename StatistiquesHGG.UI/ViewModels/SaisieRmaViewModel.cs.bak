    public int ConsultNouveauxH  { get => _consultNouveauxH;  set { SetProperty(ref _consultNouveauxH,  value); NotifyConsultTotaux(); } }
    public int ConsultNouvellesF { get => _consultNouvellesF; set { SetProperty(ref _consultNouvellesF, value); NotifyConsultTotaux(); } }
    public int ConsultNouveauxE  { get => _consultNouveauxE;  set { SetProperty(ref _consultNouveauxE,  value); NotifyConsultTotaux(); } }
    public int ConsultAnciensH   { get => _consultAnciensH;   set { SetProperty(ref _consultAnciensH,   value); NotifyConsultTotaux(); } }
    public int ConsultAnciennesF { get => _consultAnciennesF; set { SetProperty(ref _consultAnciennesF, value); NotifyConsultTotaux(); } }
    public int ConsultAnciensE   { get => _consultAnciensE;   set { SetProperty(ref _consultAnciensE,   value); NotifyConsultTotaux(); } }

    public int ConsultTotalNouveaux => ConsultNouveauxH + ConsultNouvellesF + ConsultNouveauxE;
    public int ConsultTotalAnciens  => ConsultAnciensH  + ConsultAnciennesF + ConsultAnciensE;
    public int ConsultTotalGeneral  => ConsultTotalNouveaux + ConsultTotalAnciens;

    private void NotifyConsultTotaux()
    {
        OnPropertyChanged(nameof(ConsultTotalNouveaux));
        OnPropertyChanged(nameof(ConsultTotalAnciens));
        OnPropertyChanged(nameof(ConsultTotalGeneral));
    }

