    private async Task EnregistrerMapeAsync(Utilisateur user)
    {
        // Vérifier doublon semaine/année
        var existing = await _context.SaisiesMape
            .FirstOrDefaultAsync(m => m.SemaineEpi == MapeSemaine && m.AnneeEpi == MapeAnnee);
        if (existing != null)
        {
            SetStatus($"Une saisie MAPE existe déjà pour S{MapeSemaine}/{MapeAnnee}.", false);
            return;
        }

        bool valide = EstValideDirectement(user);
        var mape = new SaisieMape
        {
            SemaineEpi = MapeSemaine, AnneeEpi = MapeAnnee,
            DateDebut = MapeDateDebut.DateTime, DateFin = MapeDateFin.DateTime,
            SaisieParId = user.Id, DateEnregistrement = DateTime.Now,
            Validee = valide, ValideeParId = valide ? user.Id : null,
            DateValidation = valide ? DateTime.Now : null
        };

        // Ajouter les lignes depuis le DataGrid
        foreach (var ligne in LignesMape)
        {
            mape.Lignes.Add(new LigneMape
            {
                Maladie    = ligne.Maladie,
                EstUrgence = ligne.EstUrgente,
                CS_0_14_M  = ligne.CS_0_14_M,  CS_0_14_F  = ligne.CS_0_14_F,
                CS_15_24_M = ligne.CS_15_24_M, CS_15_24_F = ligne.CS_15_24_F,
                CS_25_64_M = ligne.CS_25_64_M, CS_25_64_F = ligne.CS_25_64_F,
                CS_65p_M   = ligne.CS_65p_M,   CS_65p_F   = ligne.CS_65p_F,
                DC_0_14_M  = ligne.DC_0_14_M,  DC_0_14_F  = ligne.DC_0_14_F,
                DC_15_24_M = ligne.DC_15_24_M, DC_15_24_F = ligne.DC_15_24_F,
                DC_25_64_M = ligne.DC_25_64_M, DC_25_64_F = ligne.DC_25_64_F,
                DC_65p_M   = ligne.DC_65p_M,   DC_65p_F   = ligne.DC_65p_F,
                NbEchantillons = ligne.NbEchantillons,
                CasConfirmes   = ligne.CasConfirmes
            });
        }

        _context.SaisiesMape.Add(mape);
        await _context.SaveChangesAsync();
        SetStatus($"MAPE S{MapeSemaine}/{MapeAnnee} enregistrée ({LignesMape.Count} maladies).", true);

        // Réinitialiser les lignes pour la prochaine saisie
        InitMape();
        MapeSemaine++;
        OnPropertyChanged(nameof(MapeSemaine));
    }

    private void Reinitialiser()
    {
        ConsultNouveauxH = ConsultNouvellesF = ConsultNouveauxE = 0;
        ConsultAnciensH  = ConsultAnciennesF = ConsultAnciensE  = 0;
        HospHommes = HospFemmes = HospEnfants = HospJours = 0;
        ChirHommes = ChirFemmes = ChirEnfants = 0;
        DecesH = DecesF = DecesE = 0;
        LaboBackteriologie = LaboBiochimie = LaboHematologie = 0;
        LaboHormonologie = LaboImmunologie = LaboParasitologie = LaboAnatomopath = 0;
        MorgueCasH = MorgueCasF = MorgueCasE = 0;
        MorgueJoursH = MorgueJoursF = MorgueJoursE = 0;
        StatusMessage = string.Empty;
    }

    private void SetStatus(string msg, bool ok) { StatusMessage = msg; IsSuccess = ok; }

    private void NotifyOnglets()
    {
        OnPropertyChanged(nameof(ShowConsultation)); OnPropertyChanged(nameof(ShowHospitalisation));
        OnPropertyChanged(nameof(ShowChirurgie));    OnPropertyChanged(nameof(ShowUrgences));
        OnPropertyChanged(nameof(ShowDeces));        OnPropertyChanged(nameof(ShowLabo));
        OnPropertyChanged(nameof(ShowVaccination));  OnPropertyChanged(nameof(ShowBanqueSang));
        OnPropertyChanged(nameof(ShowMorgue));       OnPropertyChanged(nameof(ShowMape));
    }
}

// ===== LigneMapeVM avec SetProperty pour binding bidirectionnel =====
public class LigneMapeVM : BaseViewModel
{
    public string Maladie    { get; set; } = string.Empty;
    public bool   EstUrgente { get; set; }

    private int _cs0M, _cs0F, _cs15M, _cs15F, _cs25M, _cs25F, _cs65M, _cs65F;
    private int _dc0M, _dc0F, _dc15M, _dc15F, _dc25M, _dc25F, _dc65M, _dc65F;
    private int _nbEch, _casCon;

    public int CS_0_14_M  { get => _cs0M;  set { SetProperty(ref _cs0M,  value); OnPropertyChanged(nameof(TotalCas)); } }
    public int CS_0_14_F  { get => _cs0F;  set { SetProperty(ref _cs0F,  value); OnPropertyChanged(nameof(TotalCas)); } }
    public int CS_15_24_M { get => _cs15M; set { SetProperty(ref _cs15M, value); OnPropertyChanged(nameof(TotalCas)); } }
    public int CS_15_24_F { get => _cs15F; set { SetProperty(ref _cs15F, value); OnPropertyChanged(nameof(TotalCas)); } }
    public int CS_25_64_M { get => _cs25M; set { SetProperty(ref _cs25M, value); OnPropertyChanged(nameof(TotalCas)); } }
    public int CS_25_64_F { get => _cs25F; set { SetProperty(ref _cs25F, value); OnPropertyChanged(nameof(TotalCas)); } }
    public int CS_65p_M   { get => _cs65M; set { SetProperty(ref _cs65M, value); OnPropertyChanged(nameof(TotalCas)); } }
    public int CS_65p_F   { get => _cs65F; set { SetProperty(ref _cs65F, value); OnPropertyChanged(nameof(TotalCas)); } }

    public int DC_0_14_M  { get => _dc0M;  set { SetProperty(ref _dc0M,  value); OnPropertyChanged(nameof(TotalDeces)); } }
    public int DC_0_14_F  { get => _dc0F;  set { SetProperty(ref _dc0F,  value); OnPropertyChanged(nameof(TotalDeces)); } }
    public int DC_15_24_M { get => _dc15M; set { SetProperty(ref _dc15M, value); OnPropertyChanged(nameof(TotalDeces)); } }
    public int DC_15_24_F { get => _dc15F; set { SetProperty(ref _dc15F, value); OnPropertyChanged(nameof(TotalDeces)); } }
    public int DC_25_64_M { get => _dc25M; set { SetProperty(ref _dc25M, value); OnPropertyChanged(nameof(TotalDeces)); } }
    public int DC_25_64_F { get => _dc25F; set { SetProperty(ref _dc25F, value); OnPropertyChanged(nameof(TotalDeces)); } }
    public int DC_65p_M   { get => _dc65M; set { SetProperty(ref _dc65M, value); OnPropertyChanged(nameof(TotalDeces)); } }
    public int DC_65p_F   { get => _dc65F; set { SetProperty(ref _dc65F, value); OnPropertyChanged(nameof(TotalDeces)); } }

    public int NbEchantillons { get => _nbEch;  set => SetProperty(ref _nbEch,  value); }
    public int CasConfirmes   { get => _casCon; set => SetProperty(ref _casCon, value); }

    public int TotalCas   => _cs0M + _cs0F + _cs15M + _cs15F + _cs25M + _cs25F + _cs65M + _cs65F;
    public int TotalDeces => _dc0M + _dc0F + _dc15M + _dc15F + _dc25M + _dc25F + _dc65M + _dc65F;

    public string RowBackground => EstUrgente ? "#FFFBEB" : "White";
}

public class SaisieInfo
{
    public string   Type     { get; set; } = string.Empty;
    public string   Service  { get; set; } = string.Empty;
    public DateTime Date     { get; set; }
    public int      Total    { get; set; }
    public bool     Validee  { get; set; }
    public string   StatutLabel => Validee ? "Validée" : "En attente";
    public string   StatutColor => Validee ? "#D1FAE5" : "#FEF3C7";
}
