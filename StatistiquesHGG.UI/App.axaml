<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StatistiquesHGG.UI.App"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://StatistiquesHGG.UI/Styles/AppStyles.axaml"/>
    </Application.Styles>
    
    <Application.Resources>
        <!-- Converters globaux -->
        <local:InverseBoolConverter x:Key="InverseBoolConverter" 
                                    xmlns:local="clr-namespace:StatistiquesHGG.UI;assembly=StatistiquesHGG.UI"/>
        <local:IntToBoolConverter x:Key="IntToBoolConverter"
                                  xmlns:local="clr-namespace:StatistiquesHGG.UI;assembly=StatistiquesHGG.UI"/>
        <local:NullToBoolConverter x:Key="NullToBoolConverter"
                                   xmlns:local="clr-namespace:StatistiquesHGG.UI;assembly=StatistiquesHGG.UI"/>
    </Application.Resources>
</Application>
